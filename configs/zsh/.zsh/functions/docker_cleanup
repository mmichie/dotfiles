docker_cleanup() {
    if [[ "$1" != "-y" && "$1" != "--yes" ]]; then
        echo "Will prune: stopped containers, unused images, unused networks, and named volumes."
        echo "Named volumes are unrecoverable — back up first if needed."
        read -q "REPLY?Continue? [y/N] " || { echo; return 1; }
        echo
    fi
    docker system prune -af && docker volume prune -f
}
