# Save a command to ~/.important_commands for later recall
remember() {
    if [[ $# -eq 0 ]]; then
        echo "Usage: remember <command> - Save important command for future reference"
        return 1
    fi
    local remember_file="$HOME/.important_commands"
    # print -r, not echo: zsh echo expands \n and friends, mangling any
    # remembered command that contains backslash escapes.
    print -r -- "$(date +"%Y-%m-%d %H:%M:%S") $*" >> "$remember_file"
    echo "Command saved to $remember_file"
}
