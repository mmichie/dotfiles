# Find gum executable path (used by system_health and tips)
get_gum_path() {
    if command -v gum >/dev/null 2>&1; then
        command -v gum
    elif [[ -x "/opt/homebrew/bin/gum" ]]; then
        echo "/opt/homebrew/bin/gum"
    elif [[ -x "/usr/bin/gum" ]]; then
        echo "/usr/bin/gum"
    else
        return 1
    fi
}
