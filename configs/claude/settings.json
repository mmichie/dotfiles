{
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "ToolSearch",
      "LSP",
      "TaskGet",
      "TaskList",
      "TaskOutput",
      "Monitor",
      "WebSearch",
      "WebFetch",

      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(fd:*)",
      "Bash(find:*)",
      "Bash(ag:*)",

      "Bash(git log:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git blame:*)",
      "Bash(git branch --list:*)",
      "Bash(git branch --show-current:*)",
      "Bash(git ls-files:*)",
      "Bash(git ls-remote:*)",
      "Bash(git ls-tree:*)",
      "Bash(git rev-parse:*)",
      "Bash(git rev-list:*)",
      "Bash(git describe:*)",
      "Bash(git shortlog:*)",
      "Bash(git cat-file:*)",
      "Bash(git stash list:*)",
      "Bash(git config --get:*)",
      "Bash(git config --list:*)",
      "Bash(git remote -v)",
      "Bash(git tag --list:*)",
      "Bash(git tag -l:*)",
      "Bash(git for-each-ref:*)",
      "Bash(git count-objects:*)",
      "Bash(git name-rev:*)",

      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr status:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue status:*)",
      "Bash(gh repo view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh release list:*)",
      "Bash(gh release view:*)",
      "Bash(gh workflow list:*)",
      "Bash(gh workflow view:*)",
      "Bash(gh auth status:*)",

      "Bash(which:*)",
      "Bash(type:*)",
      "Bash(command -v:*)",
      "Bash(whoami:*)",
      "Bash(hostname:*)",
      "Bash(uname:*)",
      "Bash(id:*)",
      "Bash(printenv:*)",
      "Bash(pwd:*)",
      "Bash(date:*)",
      "Bash(uptime:*)",
      "Bash(sw_vers:*)",

      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(du:*)",
      "Bash(df:*)",
      "Bash(tree:*)",
      "Bash(bat:*)",
      "Bash(diff:*)",
      "Bash(realpath:*)",
      "Bash(readlink:*)",

      "Bash(jq:*)",
      "Bash(yq:*)",
      "Bash(uniq:*)",
      "Bash(cut:*)",
      "Bash(tr:*)",
      "Bash(column:*)",
      "Bash(base64:*)",
      "Bash(shasum:*)",

      "Bash(dig:*)",
      "Bash(nslookup:*)",
      "Bash(host:*)",
      "Bash(ping:*)",

      "Bash(ps:*)",

      "Bash(nix eval:*)",
      "Bash(nix flake show:*)",
      "Bash(nix flake metadata:*)",
      "Bash(nix search:*)",
      "Bash(nix path-info:*)",
      "Bash(nix show-derivation:*)",
      "Bash(nix why-depends:*)",
      "Bash(nix-store --query:*)",
      "Bash(nix-store -q:*)",

      "Bash(brew list:*)",
      "Bash(brew info:*)",
      "Bash(brew --prefix:*)",
      "Bash(brew deps:*)",

      "Bash(just --list:*)",
      "Bash(just -l:*)",
      "Bash(just --summary:*)",
      "Bash(just --show:*)",

      "Bash(man:*)",
      "Bash(defaults read:*)",
      "Bash(claude --version:*)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "beads@beads-marketplace": true,
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "skipDangerousModePermissionPrompt": true
}
