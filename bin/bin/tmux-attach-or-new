#!/usr/bin/env zsh
# zsh shebang is load-bearing: zsh auto-sources ~/.zshenv on start, which
# defines setup_path and runs it. That PATH then becomes tmux's client env
# (seen by run-shell) and, since tmux.conf no longer overrides it, the
# global env too (seen by #() commands). One canonical list.

# Source OPEN_WEATHER_API_KEY etc. for chevron weather in the status bar
[[ -f ~/.zshrc.local ]] && source ~/.zshrc.local

TMUX=$(command -v tmux)
if [ -z "$TMUX" ]; then
    echo "tmux not found in PATH"
    exit 1
fi

# List sessions with no clients currently attached. Skipping attached
# sessions avoids the "two Ghostty windows mirroring the same panes"
# trap that plain `attach-session` falls into.
detached=$($TMUX list-sessions -F "#{?session_attached,,#{session_name}}" 2>/dev/null | grep -v '^$')

if [ -z "$detached" ]; then
    # Either no sessions exist, or every existing session is attached elsewhere.
    # Either way, start a fresh session. Fall back to $HOME when Ghostty was
    # launched by launchd (which spawns it with cwd=/).
    startdir="$PWD"
    [ "$startdir" = "/" ] && startdir="$HOME"
    exec $TMUX new-session -c "$startdir"
fi

detached_count=$(printf '%s\n' "$detached" | wc -l | tr -d ' ')

if [ "$detached_count" -eq 1 ]; then
    exec $TMUX attach-session -t "$detached"
fi

# Multiple detached sessions — menu.
echo "Detached tmux sessions:"
echo
printf '%s\n' "$detached" | nl -w2 -s'. '
echo
echo -n "Enter session number to attach (or press Enter for first): "
read -r choice

if [ -z "$choice" ]; then
    session_name=$(printf '%s\n' "$detached" | head -1)
else
    session_name=$(printf '%s\n' "$detached" | sed -n "${choice}p")
fi
exec $TMUX attach-session -t "$session_name"
